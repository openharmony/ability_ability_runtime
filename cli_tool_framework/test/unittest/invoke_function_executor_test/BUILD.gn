import("//build/test.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

module_output_path = "ability_runtime/ability_runtime/clitool"

ohos_unittest("invoke_function_executor_test") {
  module_out_path = module_output_path

  # "mock/include" MUST come before the real interfaces/cli_tool/include so the
  # trimmed mock CliToolMGRClient shadows the real one; interfaces/cli_tool/include
  # is still needed for cli_error_code.h (no mock), and interfaces/function/include
  # for function_info.h (no mock).
  include_dirs = [
    "mock/include",
    "${cli_tool_framework_path}/frameworks/js/napi/function_manager/include",
    "${cli_tool_framework_path}/interfaces/cli_tool/include",
    "${cli_tool_framework_path}/interfaces/function/include",
    "${ability_runtime_services_path}/common/include",
    "${ability_runtime_innerkits_path}/ability_manager/include",
    "${ability_runtime_innerkits_path}/ability_manager/include/insight_intent",
    "${ability_runtime_path}/interfaces/kits/native/ability/native",
  ]

  sources = [
    "invoke_function_executor_test.cpp",
    "mock/src/intent_client.cpp",
    "mock/src/cli_tool_mgr_client.cpp",
    "${cli_tool_framework_path}/frameworks/js/napi/function_manager/src/invoke_function_callback_client.cpp",
    "${cli_tool_framework_path}/frameworks/js/napi/function_manager/src/invoke_function_executor.cpp",
    # InsightIntentExecuteResult is a Parcelable whose vtable (key function
    # Marshalling) is emitted here. The mock intent_client constructs/copies a
    # real result to deliver via the callback, so its impl must be linked in.
    "${ability_runtime_services_path}/abilitymgr/src/insight_intent/insight_intent_execute_result.cpp",
  ]

  deps = [
    # FunctionInfo is a Parcelable whose vtable (key function Marshalling) lives
    # in this source set; DoExecute constructs a local FunctionInfo.
    "${cli_tool_framework_path}/interfaces/function:function_info",
  ]

  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "c_utils:utils",
    "ffrt:libffrt",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "json:nlohmann_json_static",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":invoke_function_executor_test" ]
}
