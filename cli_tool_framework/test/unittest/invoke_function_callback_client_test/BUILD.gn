import("//build/test.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

module_output_path = "ability_runtime/ability_runtime/clitool"

ohos_unittest("invoke_function_callback_client_test") {
  module_out_path = module_output_path

  include_dirs = [
    "${cli_tool_framework_path}/frameworks/js/napi/function_manager/include",
    "${cli_tool_framework_path}/interfaces/cli_tool/include",
  ]

  sources = [
    "invoke_function_callback_client_test.cpp",
    "${cli_tool_framework_path}/frameworks/js/napi/function_manager/src/invoke_function_callback_client.cpp",
  ]

  deps = [
    "${ability_runtime_path}/interfaces/inner_api/insight_intent/intent_client:intent_client",
  ]

  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "c_utils:utils",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":invoke_function_callback_client_test" ]
}
