import("//build/ohos.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

ohos_executable("modular_object_dispatcher_c_demo") {
  sources = [ "modular_object_dispatcher_c_demo.cpp" ]

  include_dirs = [ ability_runtime_ndk_path ]

  cflags = []
  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }

  deps = [ "${ability_runtime_path}/frameworks/c/ability_runtime:ability_runtime" ]

  external_deps = [
    "ipc:ipc_capi",
    "ipc:ipc_core",
  ]

  subsystem_name = "ability"
  part_name = "ability_runtime"
}
