import("//build/ohos.gni")
import("//build/test.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

ohos_unittest("agent_remote_object_key_test") {
  module_out_path = "ability_runtime/ability_runtime/agent_runtime/agent_remote_object_key_test"

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
    blocklist = "../../../cfi_blocklist.txt"
  }

  sources = [ "agent_remote_object_key_test.cpp" ]

  include_dirs = [
    "${agent_runtime_framework_path}/frameworks/native/agent_extension/include",
  ]

  deps = []

  external_deps = [
    "c_utils:utils",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]

  cflags_cc = []

  configs = []
}

group("unittest") {
  testonly = true
  deps = [ ":agent_remote_object_key_test" ]
}
