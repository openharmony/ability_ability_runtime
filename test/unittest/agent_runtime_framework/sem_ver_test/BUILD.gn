import("//build/ohos.gni")
import("//build/test.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

ohos_unittest("sem_ver_test") {
  module_out_path = "ability_runtime/ability_runtime/agent_runtime/sem_ver_test"

  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
    blocklist = "../../../cfi_blocklist.txt"
  }

  sources = [
    "sem_ver_test.cpp",
    "${agent_runtime_framework_path}/services/common/src/sem_ver.cpp",
  ]

  include_dirs = [ "${agent_runtime_framework_path}/services/common/include" ]

  deps = []

  external_deps = [
    "googletest:gtest_main",
  ]

  cflags_cc = []

  configs = []
}

group("unittest") {
  testonly = true
  deps = [ ":sem_ver_test" ]
}
