import("//build/test.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

module_output_path = "ability_runtime/ability_runtime/abilitymgr"

ohos_unittest("native_module_util_test") {
  module_out_path = module_output_path
  sanitize = {
    cfi = true
    cfi_cross_dso = true
    debug = false
    blocklist = "../../cfi_blocklist.txt"
  }
  sources = [
    "${ability_runtime_path}/interfaces/inner_api/ability_manager/src/native_ability_util.cpp",
    "mock/src/mock_app_utils.cpp",
    "native_module_util_test.cpp",
  ]

  include_dirs = [
    "mock/include",
    "${ability_runtime_path}/interfaces/inner_api/ability_manager/include",
    "${ability_runtime_services_path}/common/include",
  ]

  external_deps = [
    "hilog:libhilog",
    "hitrace:hitrace_meter",
  ]
}

group("unittest") {
  testonly = true

  deps = [ ":native_module_util_test" ]
}
