import("//build/test.gni")
import("//foundation/ability/ability_runtime/ability_runtime.gni")

ohos_unittest("insight_intent_param_parser_test") {
  module_out_path = "ability_runtime/ability_runtime/insight_intent"

  sources = [
    "${ability_runtime_services_path}/abilitymgr/src/insight_intent/extract_insight_intent_profile.cpp",
    "${ability_runtime_services_path}/abilitymgr/src/insight_intent/function_call_convert.cpp",
    "${ability_runtime_services_path}/abilitymgr/src/insight_intent/insight_intent_execute_result.cpp",
    "${ability_runtime_services_path}/abilitymgr/src/insight_intent/insight_intent_param_parser.cpp",
    "${ability_runtime_services_path}/abilitymgr/src/insight_intent/insight_intent_profile.cpp",
    "${ability_runtime_services_path}/abilitymgr/src/utils/hmsf_utils.cpp",
    "insight_intent_param_parser_test.cpp",
  ]

  configs = [ "${ability_runtime_services_path}/abilitymgr:abilityms_config" ]

  cflags = []
  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }

  include_dirs = [
    "${ability_runtime_services_path}/abilitymgr/include",
    "${ability_runtime_services_path}/abilitymgr/include/insight_intent",
    "${ability_runtime_innerkits_path}/ability_manager/include",
    "${ability_runtime_innerkits_path}/ability_manager/include/insight_intent",
  ]

  deps = [
    "${ability_runtime_innerkits_path}/ability_manager:ability_manager",
    "${ability_runtime_services_path}/abilitymgr:abilityms",
    "${ability_runtime_services_path}/common:app_util",
  ]

  external_deps = [
    "ability_base:want",
    "c_utils:utils",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "nlohmann_json:nlohmann_json",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":insight_intent_param_parser_test" ]
}
