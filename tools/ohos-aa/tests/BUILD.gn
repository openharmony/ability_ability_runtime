    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]
}

group("unittest") {
  testonly = true

  deps = [
    ":ohos_aa_command_start_test",
    ":ohos_aa_command_force_stop_test",
    ":ohos_aa_command_util_test",
  ]
}
