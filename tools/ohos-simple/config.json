{
  "name": "ohos-simple",
  "version": "1.0.0",
  "description": "Simple CLI tool, supports message output, repeat count and verbose mode",
  "executablePath": "/system/bin/cli_tool/executable/ohos-simple",
  "requirePermissions": [],
  "inputSchema": {
    "type": "object",
    "description": "Tool input parameters",
    "properties": {
      "message": {
        "type": "string",
        "description": "Message content to output",
        "default": "Hello from ohos-simple",
        "minLength": 1
      },
      "count": {
        "type": "integer",
        "description": "Message repeat count, actual implementation will limit between 1 and 10",
        "default": 1,
        "minimum": 1,
        "maximum": 10
      },
      "verbose": {
        "type": "boolean",
        "description": "Whether to output detailed process information",
        "default": false
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "description": "Tool execution result",
    "properties": {
      "message": {
        "type": "string",
        "description": "Processed output message"
      },
      "repeat_count": {
        "type": "integer",
        "description": "Actual repeat count"
      }
    },
    "required": ["message", "repeat_count"]
  }
}
