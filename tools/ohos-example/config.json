{
  "name": "ohos-example",
  "version": "1.0.0",
  "description": "Example CLI tool, demonstrates CLI tool specification implementation (with subcommand format)",
  "executablePath": "/system/bin/cli_tool/executable/ohos-example",
  "hasSubCommand": true,
  "requirePermissions": [],
  "inputSchema": {
    "type": "object",
    "properties": {}
  },
  "outputSchema": {
    "type": "object",
    "properties": {}
  },
  "subcommands": {
    "run": {
      "description": "Run example tool, execute and return results",
      "requirePermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {
          "argLine": {
            "type": "string",
            "description": "Argument string to pass to the tool"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "description": "Execution result",
        "properties": {
          "result": {
            "type": "string",
            "description": "Execution result string"
          }
        }
      },
      "eventTypes": ["progress"],
      "eventSchemas": {
        "progress": {
          "type": "object",
          "description": "Execution progress event",
          "properties": {
            "type": {
              "const": "progress"
            },
            "percentage": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Completion percentage"
            },
            "status": {
              "type": "string",
              "description": "Current status"
            }
          },
          "required": ["type", "percentage", "status"]
        }
      }
    },
    "version": {
      "description": "Display version information",
      "requirePermissions": [],
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "outputSchema": {
        "type": "object",
        "description": "Version information",
        "properties": {
          "version": {
            "type": "string",
            "description": "Tool version number"
          },
          "build_time": {
            "type": "string",
            "description": "Build time"
          }
        },
        "required": ["version"]
      }
    }
  }
}
