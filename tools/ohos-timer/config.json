{
  "name": "ohos-timer",
  "version": "1.0.0",
  "description": "Timer tool example, supports progress event output",
  "executablePath": "/system/bin/cli_tool/executable/ohos-timer",
  "requirePermissions": [],
  "eventTypes": ["progress"],
  "inputSchema": {
    "type": "object",
    "description": "Tool input parameters",
    "properties": {
      "duration": {
        "type": "integer",
        "description": "Running duration (seconds)",
        "minimum": 1
      },
      "interval": {
        "type": "integer",
        "description": "Progress update interval (seconds)",
        "default": 1,
        "minimum": 1
      },
      "showProgress": {
        "type": "boolean",
        "description": "Show progress events",
        "default": false
      },
      "verbose": {
        "type": "boolean",
        "description": "Verbose mode",
        "default": false
      }
    },
    "required": ["duration"]
  },
  "outputSchema": {
    "type": "object",
    "description": "Tool output result",
    "properties": {
      "duration": {
        "type": "integer",
        "description": "Planned duration (seconds)"
      },
      "actual_duration": {
        "type": "integer",
        "description": "Actual duration (seconds)"
      }
    },
    "required": ["duration", "actual_duration"]
  },
  "eventSchemas": {
    "progress": {
      "type": "object",
      "description": "Progress event",
      "properties": {
        "type": {
          "const": "progress"
        },
        "percentage": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Completion percentage"
        },
        "status": {
          "type": "string",
          "description": "Current status"
        }
      },
      "required": ["type", "percentage", "status"]
    }
  }
}
