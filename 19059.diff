+{
+    auto typeInfo = MakeTypeInfo(OH_ABILITY_RUNTIME_MO_DISPATCHER_VT_I32);
+    auto ret = OH_AbilityRuntime_MoDispatcher_Array_Create(&typeInfo, 2, &array_);
+    EXPECT_EQ(ret, ABILITY_RUNTIME_ERROR_CODE_NO_ERROR);
+
+    auto v = MakeI32(100);
