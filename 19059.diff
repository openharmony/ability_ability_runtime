+    std::unordered_map<std::string, uint32_t> nameToMemberId_;
+    std::unordered_map<uint32_t, std::string> memberIdToName_;
+    std::unordered_map<uint32_t, MoMethodMeta> memberIdToMethod_;
+
+    mutable std::mutex mutex_;
