+class MoDispatcherArrayTest : public ::testing::Test {
+protected:
+    void TearDown() override
+    {
+        if (array_ != nullptr) {
+            OH_AbilityRuntime_MoDispatcher_Array_Release(&array_);
+        }
+    }
+    OH_AbilityRuntime_MoDispatcher_ArrayHandle array_ = nullptr;
