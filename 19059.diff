+const MoInterfaceMeta* FindInterfaceByName(const std::vector<MoInterfaceMeta>& interfaces,
+    const std::string& name)
+{
+    for (const auto& item : interfaces) {
+        if (item.name == name) {
+            return &item;
+        }
+    }
+    return nullptr;
+}
