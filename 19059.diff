+void OH_AbilityRuntime_MoDispatcher_Release(OH_AbilityRuntime_MoDispatcherHandle* ppMoDispatcher)
+{
+    if (ppMoDispatcher == nullptr || *ppMoDispatcher == nullptr) {
+        return;
+    }
+    delete *ppMoDispatcher;
+    *ppMoDispatcher = nullptr;
