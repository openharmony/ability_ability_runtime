+const MoMethodMeta* FindMethodByName(const std::vector<MoMethodMeta>& methods, const std::string& name)
+{
+    for (const auto& item : methods) {
+        if (item.name == name) {
+            return &item;
+        }
+    }
+    return nullptr;
+}
